# Porta da API (padrão: 3001)
PORT=3001

# CORS — coloque a URL do seu frontend em produção
# Ex: https://seudominio.com ou * para desenvolvimento
CORS_ORIGIN=*

# ─── Email (opcional) ───────────────────────────────
# Se não configurar, os leads são apenas logados no console.
# Funciona com qualquer SMTP: Gmail, Brevo, Resend, etc.

# Gmail: use uma App Password (não a senha normal)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_app_password_aqui

# Para onde os leads chegam
LEAD_EMAIL=seuemail@gmail.com
